{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fireworldbench.invalid/v2/fire_event.schema.json",
  "title": "FireWorldBench v2 Fire Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "event_id", "event_group", "source_domain", "status",
    "geometry", "controls", "timeline", "observations", "ground_truth",
    "provenance", "license"
  ],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "event_id": {"type": "string", "pattern": "^FWE-[A-F0-9]{12}$"},
    "event_group": {"type": "string", "pattern": "^FWG-[A-F0-9]{12}$"},
    "source_domain": {
      "enum": ["fds", "immersed_tunnel", "polyu", "furg_fire_substitute", "kaggle_video_supplement", "deepquest_fire_smoke", "dfire", "fire360", "detectium", "fire360_mirror"]
    },
    "status": {"enum": ["candidate", "eligible", "ambiguous", "excluded", "failed"]},
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scene_type", "coordinate_system", "dimensions_m", "regions"],
      "properties": {
        "scene_type": {"enum": ["tunnel", "room", "external_visual", "unknown"]},
        "coordinate_system": {"type": "string", "minLength": 1},
        "dimensions_m": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["length", "width", "height"],
              "properties": {
                "length": {"type": "number", "exclusiveMinimum": 0},
                "width": {"type": "number", "exclusiveMinimum": 0},
                "height": {"type": "number", "exclusiveMinimum": 0}
              }
            }
          ]
        },
        "regions": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["region_id", "description", "bounds_m"],
            "properties": {
              "region_id": {"type": "string", "pattern": "^R[1-8]$"},
              "description": {"type": "string"},
              "bounds_m": {"type": ["array", "null"], "items": {"type": "number"}, "minItems": 6, "maxItems": 6}
            }
          }
        }
      }
    },
    "controls": {
      "type": ["object", "null"],
      "properties": {
        "source_region": {"type": ["string", "null"], "pattern": "^R[1-8]$"},
        "hrr_profile": {"type": ["string", "null"]},
        "ventilation": {"type": ["object", "null"]},
        "extraction": {"type": ["object", "null"]},
        "openings": {"type": ["array", "null"], "items": {"type": "object"}},
        "random_seed": {"type": ["integer", "null"]},
        "intervention": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["variable", "value", "base_event_id"],
              "properties": {
                "variable": {"type": "string", "minLength": 1},
                "value": {},
                "base_event_id": {"type": "string", "pattern": "^FWE-[A-F0-9]{12}$"}
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_s", "end_s", "sample_interval_s"],
      "properties": {
        "start_s": {"type": "number", "minimum": 0},
        "end_s": {"type": "number", "exclusiveMinimum": 0},
        "sample_interval_s": {"type": ["number", "null"], "exclusiveMinimum": 0}
      }
    },
    "observations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["structured", "images", "video"],
      "properties": {
        "structured": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["ref", "format", "variables", "units_normalized"],
              "properties": {
                "ref": {"type": "string", "minLength": 1},
                "format": {"enum": ["json", "jsonl", "csv", "parquet", "text_summary"]},
                "variables": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
                "units_normalized": {"type": "boolean"}
              }
            }
          ]
        },
        "images": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 4,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["ref", "time_s", "sha256"],
                "properties": {
                  "ref": {"type": "string", "minLength": 1},
                  "time_s": {"type": "number", "minimum": 0},
                  "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
                }
              }
            }
          ]
        },
        "video": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["ref", "start_s", "duration_s", "fps", "width", "height", "sha256"],
              "properties": {
                "ref": {"type": "string", "minLength": 1},
                "start_s": {"type": "number", "minimum": 0},
                "duration_s": {"type": "number", "minimum": 4, "maximum": 12},
                "fps": {"type": "number", "exclusiveMinimum": 0},
                "width": {"type": "integer", "minimum": 1},
                "height": {"type": "integer", "minimum": 1},
                "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
              }
            }
          ]
        }
      }
    },
    "ground_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["labels"],
      "properties": {
        "labels": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "value", "origin", "rule_version"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "value": {},
              "origin": {"enum": ["source_measurement", "simulation_truth", "deterministic_rule", "expert_review"]},
              "rule_version": {"type": ["string", "null"]}
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_version", "source_files", "transform_version", "created_at", "fds"],
      "properties": {
        "source_version": {"type": "string", "minLength": 1},
        "source_files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["opaque_ref", "sha256"],
            "properties": {
              "opaque_ref": {"type": "string", "minLength": 1},
              "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
            }
          }
        },
        "transform_version": {"type": "string", "minLength": 1},
        "created_at": {"type": "string", "format": "date-time"},
        "fds": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["fds_version", "smokeview_version", "fdgen_version", "mesh", "boundary_hash", "random_seed", "input_sha256", "log_ref", "run_status"],
              "properties": {
                "fds_version": {"type": "string", "minLength": 1},
                "smokeview_version": {"type": "string", "minLength": 1},
                "fdgen_version": {"type": "string", "minLength": 1},
                "mesh": {"type": "object"},
                "boundary_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
                "random_seed": {"type": "integer"},
                "input_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
                "log_ref": {"type": "string", "minLength": 1},
                "run_status": {"enum": ["success", "failed", "numerical_anomaly", "render_error"]}
              }
            }
          ]
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["license_id", "evidence_ref", "citation", "allowed_uses", "redistribution"],
      "properties": {
        "license_id": {"type": ["string", "null"]},
        "evidence_ref": {"type": ["string", "null"]},
        "citation": {"type": "string", "minLength": 1},
        "allowed_uses": {"type": "array", "items": {"enum": ["research", "training", "evaluation", "derivation", "redistribution"]}, "uniqueItems": true},
        "redistribution": {"enum": ["allowed", "restricted", "prohibited", "unknown"]}
      }
    }
  }
}
