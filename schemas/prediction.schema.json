{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fireworldbench.invalid/schemas/prediction.schema.json",
  "title": "FireWorldBench Model Prediction",
  "type": "object",
  "additionalProperties": false,
  "required": ["sample_id", "answer", "evidence", "uncertainty", "missing_information"],
  "properties": {
    "sample_id": {"type": "string", "pattern": "^FWB-[A-Za-z0-9._-]+$"},
    "answer": {"type": "object", "minProperties": 1, "additionalProperties": true},
    "risk_level": {"type": ["string", "null"]},
    "dominant_mechanism": {"type": ["string", "null"]},
    "causal_chain": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "reason"],
      "properties": {
        "level": {"enum": ["low", "medium", "high", "unknown"]},
        "reason": {"type": "string"}
      }
    },
    "missing_information": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}

