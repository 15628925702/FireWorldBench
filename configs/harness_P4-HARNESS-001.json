{
  "harness_version": "P4-HARNESS-001",
  "allowed_splits": ["train_id", "dev_id"],
  "forbidden_splits": ["test_id", "test_ood_source_location", "test_ood_ventilation", "test_ood_hrr", "test_ood_geometry_or_layout", "test_external_experiment"],
  "default_max_retries": 0,
