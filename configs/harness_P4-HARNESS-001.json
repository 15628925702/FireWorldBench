  "overwrite_policy": "reject existing run output directory",
  "public_fields": ["sample_id", "task", "split", "status", "attempts", "latency_ms", "prompt_hash", "config_hash", "raw_response_ref"],
  "private_fields": ["raw_response", "tool_trace"],
  "private_root_mount": "forbidden_for_ordinary_harness",
  "test_asset_policy": "never read test input, test gold, or private mapping"
}
