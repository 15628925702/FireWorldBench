{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fireworldbench.invalid/v2/prediction.schema.json",
  "title": "FireWorldBench v2 Prediction",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "qa_id", "task_id", "answer", "confidence", "evidence"],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "qa_id": {"type": "string", "pattern": "^FWQ-[A-F0-9]{12}$"},
    "task_id": {"enum": ["L1-1", "L1-2", "L1-3", "L2-1", "L2-2", "L2-3", "L3-1", "L3-2", "L3-3"]},
    "answer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["choice", "fields"],
      "properties": {
        "choice": {"type": ["string", "null"]},
        "fields": {"type": "object"}
      }
    },
    "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "evidence": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}
